/**app.wxss — MCGA Coffee · iOS 26 Glass Morphism Design System**/
page {
  background: #F2F2F7;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'SF Pro Display', 'Helvetica Neue', sans-serif;
  color: #1C1C1E;
  font-size: 28rpx;
  line-height: 1.6;
  overflow-x: hidden;
  width: 100%;
  max-width: 100vw;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

button {
  background: initial;
  line-height: inherit;
  font-size: inherit;
  padding: 0;
  margin: 0;
}

button::after { border: none; }

/* Cards — iOS grouped style */
.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 0 32rpx 24rpx;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04);
}

/* Glass morphism card variant */
.glass-card {
  backdrop-filter: blur(20px);
  background: rgba(255,255,255,0.72);
  border-radius: 24rpx;
  border: 0.5rpx solid rgba(255,255,255,0.5);
  padding: 32rpx;
  margin: 0 32rpx 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.section-title .icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

/* Tags */
.tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  line-height: 1.6;
}

.tag-method {
  background: #F2F2F7;
  color: #636366;
}

.tag-roast {
  background: #E5E5EA;
  color: #3A3A3C;
}

/* Taste tags */
.tag-good { background: rgba(52, 199, 89, 0.12); color: #34C759; }
.tag-bad { background: rgba(255, 59, 48, 0.12); color: #FF3B30; }
.tag-reason { background: #F2F2F7; color: #636366; font-size: 22rpx; }

/* Glass overlay & popup */
.glass-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.3);
  backdrop-filter: blur(10px);
  z-index: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.glass-popup {
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(30px);
  border-radius: 28rpx;
  padding: 48rpx;
  margin: 0 40rpx;
  border: 0.5rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 8rpx 48rpx rgba(0,0,0,0.12);
}

/* Animation utility */
.fade-in {
  animation: fadeIn 0.4s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* Primary button */
.btn-primary {
  background: #1C1C1E !important;
  color: #FFFFFF !important;
  border-radius: 48rpx !important;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.btn-primary:active { opacity: 0.85; }

/* Form elements */
.form-group { margin-bottom: 28rpx; }

.form-label {
  font-size: 26rpx;
  color: #8E8E93;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 0.5rpx solid #D1D1D6;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1C1C1E;
  background: #FFFFFF;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  border: 0.5rpx solid #D1D1D6;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1C1C1E;
  background: #FFFFFF;
  box-sizing: border-box;
}

/* Loading & Empty */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.loading-text {
  font-size: 24rpx;
  color: #8E8E93;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon { font-size: 120rpx; margin-bottom: 32rpx; }
.empty-title { font-size: 34rpx; font-weight: 600; color: #1C1C1E; margin-bottom: 16rpx; }
.empty-desc { font-size: 26rpx; color: #8E8E93; text-align: center; }

/* Retry Button */
.retry-btn {
  margin-top: 40rpx;
  padding: 16rpx 48rpx;
  background: #E5E5EA;
  border-radius: 40rpx;
  color: #3A3A3C;
  font-size: 28rpx;
  font-weight: 500;
}

.retry-btn:active {
  opacity: 0.7;
}