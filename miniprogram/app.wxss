/**app.wxss — MCGA Coffee · Apple iOS Theme**/
page {
  background: #F2F2F7;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'SF Pro Display', 'Helvetica Neue', sans-serif;
  color: #1C1C1E;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

button {
  background: initial;
  line-height: inherit;
  font-size: inherit;
  padding: 0;
  margin: 0;
}

button::after { border: none; }

/* Cards — iOS grouped style */
.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 0 32rpx 24rpx;
  box-shadow: none;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.section-title .icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

/* Rating stars */
.rating-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.rating-label {
  font-size: 28rpx;
  color: #3A3A3C;
  min-width: 120rpx;
}

.rating-stars {
  display: flex;
  gap: 16rpx;
}

.star {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #D1D1D6;
}

.star.active {
  color: #636366;
}

/* Tags */
.tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  line-height: 1.6;
}

.tag-method {
  background: #F2F2F7;
  color: #636366;
}

.tag-roast {
  background: #E5E5EA;
  color: #3A3A3C;
}

/* Primary button */
.btn-primary {
  background: #1C1C1E !important;
  color: #FFFFFF !important;
  border-radius: 48rpx !important;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.btn-primary:active { opacity: 0.85; }

/* Form elements */
.form-group { margin-bottom: 28rpx; }

.form-label {
  font-size: 26rpx;
  color: #8E8E93;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 0.5rpx solid #D1D1D6;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1C1C1E;
  background: #FFFFFF;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  border: 0.5rpx solid #D1D1D6;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1C1C1E;
  background: #FFFFFF;
  box-sizing: border-box;
}

/* Loading & Empty */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.loading-text {
  font-size: 24rpx;
  color: #8E8E93;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon { font-size: 120rpx; margin-bottom: 32rpx; }
.empty-title { font-size: 34rpx; font-weight: 600; color: #1C1C1E; margin-bottom: 16rpx; }
.empty-desc { font-size: 26rpx; color: #8E8E93; text-align: center; }

/* Retry Button */
.retry-btn {
  margin-top: 40rpx;
  padding: 16rpx 48rpx;
  background: #E5E5EA;
  border-radius: 40rpx;
  color: #3A3A3C;
  font-size: 28rpx;
  font-weight: 500;
}

.retry-btn:active {
  opacity: 0.7;
}