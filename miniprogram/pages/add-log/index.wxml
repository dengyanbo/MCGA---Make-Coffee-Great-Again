<wxs src="../../utils/filters.wxs" module="f" />

<scroll-view scroll-y class="page-add">
  <!-- Bean Info -->
  <view class="card">
    <view class="form-group">
      <text class="form-label">咖啡豆名称 *</text>
      <input class="form-input" placeholder="如：埃塞俄比亚 耶加雪菲" value="{{beanName}}" bindinput="onInputBeanName" />
    </view>
    <view class="roast-row">
      <text class="form-label">烘焙度</text>
      <view class="roast-beans">
        <view class="roast-bean {{roastIndex >= 0 ? 'active' : ''}}" data-level="{{0}}" bindtap="onPickRoast">
          <image class="roast-img" src="{{roastImages[0]}}" mode="aspectFit" /></view>
        <view class="roast-bean {{roastIndex >= 1 ? 'active' : ''}}" data-level="{{1}}" bindtap="onPickRoast">
          <image class="roast-img" src="{{roastImages[1]}}" mode="aspectFit" /></view>
        <view class="roast-bean {{roastIndex >= 2 ? 'active' : ''}}" data-level="{{2}}" bindtap="onPickRoast">
          <image class="roast-img" src="{{roastImages[2]}}" mode="aspectFit" /></view>
        <view class="roast-bean {{roastIndex >= 3 ? 'active' : ''}}" data-level="{{3}}" bindtap="onPickRoast">
          <image class="roast-img" src="{{roastImages[3]}}" mode="aspectFit" /></view>
        <view class="roast-bean {{roastIndex >= 4 ? 'active' : ''}}" data-level="{{4}}" bindtap="onPickRoast">
          <image class="roast-img" src="{{roastImages[4]}}" mode="aspectFit" /></view>
      </view>
      <text class="roast-label">{{roastIndex >= 0 ? roastLevels[roastIndex] : ''}}</text>
    </view>
  </view>

  <!-- Brew Method -->
  <view class="card">
    <view class="glass-segmented" id="brewSegmented"
      bindtouchstart="onBrewTouchStart" bindtouchmove="onBrewTouchMove">
      <view class="glass-indicator" wx:if="{{brewMethodIndex >= 0}}"
        style="width: 50%; transform: translateX({{brewMethodIndex * 100}}%)"></view>
      <view class="glass-segment {{brewMethod === item.value ? 'active' : ''}}"
        wx:for="{{brewMethods}}" wx:key="value"
        data-value="{{item.value}}" bindtap="onSelectMethod">
        <text class="glass-segment-icon">{{item.icon}}</text>
        <text class="glass-segment-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- Brew Parameters — 2-column grid -->
  <view class="card">
    <!-- Grinder Model (text input, full width) -->
    <view class="form-group">
      <text class="form-label">磨豆机型号</text>
      <input class="form-input" placeholder="如：Comandante C40" value="{{grinderModel}}" bindinput="onInputGrinderModel" />
    </view>
    <view class="form-group">
      <text class="form-label">滤杯型号</text>
      <view wx:if="{{filterCups.length > 0}}" class="filter-cup-row">
        <view class="filter-cup-select" bindtap="onSelectFilterCup">
          <text>{{filterCup || '选择滤杯'}}</text>
          <text class="brew-param-arrow">›</text>
        </view>
      </view>
      <input wx:else class="form-input" placeholder="如：Hario V60" value="{{filterCup}}" bindinput="onInputFilterCup" />
    </view>

    <view class="param-grid">
      <view class="param-grid-cell" data-field="grindSize" bindtap="onTapParam">
        <view class="param-grid-inner">
          <text class="param-grid-label">研磨度</text>
          <text class="param-grid-value">{{grindSize != null ? grindSize : '--'}} <text class="param-grid-unit">格</text></text>
        </view>
      </view>
      <view class="param-grid-cell" data-field="coffeeDose" bindtap="onTapParam">
        <view class="param-grid-inner">
          <text class="param-grid-label">粉量</text>
          <text class="param-grid-value">{{coffeeDose != null ? coffeeDose : '--'}} <text class="param-grid-unit">g</text></text>
        </view>
      </view>
      <view class="param-grid-cell" data-field="waterAmount" bindtap="onTapParam">
        <view class="param-grid-inner">
          <text class="param-grid-label">水量</text>
          <text class="param-grid-value">{{waterAmount != null ? waterAmount : '--'}} <text class="param-grid-unit">ml</text></text>
        </view>
      </view>
      <view class="param-grid-cell" data-field="waterTemp" bindtap="onTapParam">
        <view class="param-grid-inner">
          <text class="param-grid-label">水温</text>
          <text class="param-grid-value">{{waterTemp != null ? waterTemp : '--'}} <text class="param-grid-unit">°C</text></text>
        </view>
      </view>
      <view class="param-grid-cell" data-field="brewTime" bindtap="onTapParam">
        <view class="param-grid-inner">
          <text class="param-grid-label">萃取时间</text>
          <text class="param-grid-value">{{brewTime != null ? brewTime : '--'}} <text class="param-grid-unit">秒</text></text>
        </view>
      </view>
      <view class="param-grid-cell" wx:if="{{coffeeDose && waterAmount}}">
        <view class="param-grid-inner">
          <text class="param-grid-label">粉水比</text>
          <text class="param-grid-value">{{f.formatRatio(coffeeDose, waterAmount)}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Environment -->
  <view class="card">
    <view class="param-grid">
      <view class="param-grid-cell" data-field="ambientTemp" bindtap="onTapParam">
        <view class="param-grid-inner">
          <text class="param-grid-label">气温</text>
          <text class="param-grid-value">{{ambientTemp != null ? ambientTemp : '--'}} <text class="param-grid-unit">°C</text></text>
        </view>
      </view>
      <view class="param-grid-cell" data-field="humidity" bindtap="onTapParam">
        <view class="param-grid-inner">
          <text class="param-grid-label">湿度</text>
          <text class="param-grid-value">{{humidity != null ? humidity : '--'}} <text class="param-grid-unit">%</text></text>
        </view>
      </view>
    </view>
    <view class="form-group" style="margin-top: 20rpx;">
      <view class="collapsible-toggle" bindtap="toggleRemarks">
        <text class="form-label" style="margin-bottom: 0;">备注</text>
        <text class="collapse-arrow {{remarksExpanded ? 'expanded' : ''}}">▾</text>
      </view>
      <view class="collapsible-body {{remarksExpanded ? 'expanded' : ''}}">
        <textarea class="form-textarea" placeholder="冲煮备注..." value="{{remarks}}" bindinput="onInputRemarks" maxlength="200" />
      </view>
    </view>
  </view>

  <!-- Taste Rating -->
  <view class="card">
    <view class="section-title"><text class="icon">☕</text><text>味道评价</text></view>
    <view class="taste-buttons">
      <view class="taste-btn {{taste === 'good' ? 'taste-btn-good-active' : ''}}" data-taste="good" bindtap="onSelectTaste">
        <text class="taste-btn-emoji">👍</text>
        <text class="taste-btn-label">好喝</text>
      </view>
      <view class="taste-btn {{taste === 'bad' ? 'taste-btn-bad-active' : ''}}" data-taste="bad" bindtap="onSelectTaste">
        <text class="taste-btn-emoji">👎</text>
        <text class="taste-btn-label">难喝</text>
      </view>
    </view>

    <!-- Bad reasons (shown when taste is bad) -->
    <view wx:if="{{taste === 'bad'}}" class="bad-reasons-section">
      <text class="form-label" style="margin-top: 24rpx;">哪里不好？</text>
      <view class="bad-reason-chips">
        <view class="bad-reason-chip {{badReasons.indexOf('too_bitter') >= 0 ? 'selected' : ''}}" data-reason="too_bitter" bindtap="onToggleBadReason">
          <text>太苦</text>
        </view>
        <view class="bad-reason-chip {{badReasons.indexOf('too_sour') >= 0 ? 'selected' : ''}}" data-reason="too_sour" bindtap="onToggleBadReason">
          <text>太酸</text>
        </view>
      </view>
      <input class="form-input" placeholder="其他原因..." value="{{customBadReason}}" bindinput="onCustomBadReasonInput" style="margin-top: 16rpx;" />
    </view>
  </view>

  <!-- Tasting Notes -->
  <view class="card">
    <view class="section-title" bindtap="toggleNotes">
      <text class="icon">📝</text><text>品鉴笔记</text>
      <text class="collapse-arrow {{notesExpanded ? 'expanded' : ''}}">▾</text>
    </view>
    <view class="collapsible-body {{notesExpanded ? 'expanded' : ''}}">
      <textarea class="form-textarea" placeholder="记录这杯咖啡的风味、口感和心得..." value="{{notes}}" bindinput="onInputNotes" maxlength="500" />
    </view>
  </view>

  <!-- Submit -->
  <view class="submit-wrap">
    <button class="btn-primary" bindtap="onSubmit" disabled="{{submitting}}">
      {{submitting ? '保存中...' : (isEdit ? '更新记录' : '保存记录')}}
    </button>
  </view>
  <view class="safe-bottom"></view>
</scroll-view>

<!-- Scroll Wheel Picker Bottom Sheet -->
<view wx:if="{{pickerVisible}}" class="picker-mask" bindtap="onPickerCancel">
  <view class="picker-sheet" catchtap="">
    <view class="picker-header">
      <text class="picker-cancel" bindtap="onPickerCancel">取消</text>
      <text class="picker-title">{{pickerLabel}}</text>
      <text class="picker-confirm" bindtap="onPickerConfirm">确定</text>
    </view>
    <picker-view value="{{pickerIndex}}" bindchange="onPickerChange" class="picker-body" indicator-style="height: 80rpx;">
      <picker-view-column>
        <view wx:for="{{pickerValues}}" wx:key="*this" class="picker-item">
          {{item}} {{pickerUnit}}
        </view>
      </picker-view-column>
    </picker-view>
  </view>
</view>
