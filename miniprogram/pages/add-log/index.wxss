.page-add {
  height: 100vh;
}

/* Roast Bean Picker */
.roast-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.roast-row .form-label {
  margin-bottom: 0;
  flex-shrink: 0;
}

.roast-beans {
  display: flex;
  gap: 16rpx;
}

.roast-bean {
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.roast-img {
  width: 56rpx;
  height: 56rpx;
  filter: grayscale(100%);
  opacity: 0.5;
  transition: filter 0.2s, opacity 0.2s;
}

.roast-bean.active .roast-img {
  filter: grayscale(0%);
  opacity: 1;
}

.roast-label {
  font-size: 26rpx;
  color: #8E8E93;
  flex-shrink: 0;
  min-width: 56rpx;
  text-align: right;
  margin-left: auto;
}

/* Glass Segmented Control (iOS style) */
.glass-segmented {
  display: flex;
  position: relative;
  background: rgba(118, 118, 128, 0.12);
  border-radius: 20rpx;
  border: none;
}

.glass-indicator {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 50%;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08), 0 1rpx 2rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 0;
}

.glass-segment {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx 0;
  position: relative;
  z-index: 1;
  color: #8E8E93;
  transition: color 0.25s;
}

.glass-segment.active {
  color: #1C1C1E;
  font-weight: 600;
}

.glass-segment-icon {
  font-size: 32rpx;
}

.glass-segment-label {
  font-size: 26rpx;
  font-weight: 500;
}

/* Collapsible Sections */
.collapsible-toggle {
  display: flex;
  align-items: center;
}

.collapse-arrow {
  font-size: 22rpx;
  color: #C7C7CC;
  margin-left: auto;
  transition: transform 0.3s ease;
}

.collapse-arrow.expanded {
  transform: rotate(180deg);
}

.collapsible-body {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: max-height 0.3s ease, opacity 0.25s ease;
}

.collapsible-body.expanded {
  max-height: 500rpx;
  opacity: 1;
}

/* Glass Rating Segmented */
.glass-rating {
  flex: 1;
  margin-left: 12rpx;
}

.glass-rating-track {
  position: relative;
  display: flex;
  background: rgba(118, 118, 128, 0.12);
  border-radius: 16rpx;
  border: none;
  overflow: hidden;
}

.glass-rating-slider {
  position: absolute;
  top: 0;
  left: 0;
  bottom: 0;
  background: rgba(142, 142, 147, 0.18);
  border-radius: 16rpx;
  transition: width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 0;
}

.glass-rating-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  position: relative;
  z-index: 1;
  border-right: 0.5rpx solid rgba(118, 118, 128, 0.12);
}

.glass-rating-option:last-child {
  border-right: none;
}

.glass-rating-num {
  font-size: 24rpx;
  color: transparent;
  font-weight: 600;
  position: relative;
  z-index: 2;
}

.glass-rating-num.visible {
  color: #3A3A3C;
}

/* Param List— iOS grouped list style */
.param-list {
  border-radius: 20rpx;
  overflow: hidden;
  border: none;
}

.param-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #FFFFFF;
  border-bottom: 0.5rpx solid #F2F2F7;
}

.param-cell:last-child {
  border-bottom: none;
}

.param-cell:active {
  background: #F2F2F7;
}

.param-cell-label {
  font-size: 28rpx;
  color: #1C1C1E;
  font-weight: 500;
}

.param-cell-right {
  display: flex;
  align-items: center;
}

.param-cell-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-right: 8rpx;
}

.param-cell-unit {
  font-size: 24rpx;
  color: #8E8E93;
  margin-right: 12rpx;
}

.param-cell-arrow {
  font-size: 22rpx;
  color: #C7C7CC;
}

/* Two-column param grid */
.param-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}

.param-grid-cell {
  width: 50%;
  box-sizing: border-box;
  padding: 8rpx;
}

.param-grid-inner {
  background: #FFFFFF;
  border: 0.5rpx solid #E5E5EA;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.param-grid-inner:active {
  background: #F2F2F7;
}

.param-grid-label {
  font-size: 22rpx;
  color: #8E8E93;
  margin-bottom: 8rpx;
  display: block;
}

.param-grid-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
  display: block;
}

.param-grid-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: #8E8E93;
}

/* Picker */
.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.placeholder {
  color: #C7C7CC;
}

.picker-arrow {
  color: #C7C7CC;
  font-size: 24rpx;
}

/* Submit */
.submit-wrap {
  padding: 32rpx;
}

.safe-bottom {
  height: 60rpx;
}

/* ========== Scroll Wheel Picker Bottom Sheet ========== */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.picker-sheet {
  width: 100%;
  background: #F2F2F7;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 0.5rpx solid #E5E5EA;
  background: #FFFFFF;
}

.picker-cancel {
  font-size: 30rpx;
  color: #8E8E93;
  padding: 8rpx 16rpx;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1C1E;
}

.picker-confirm {
  font-size: 30rpx;
  color: #3A3A3C;
  font-weight: 600;
  padding: 8rpx 16rpx;
}

.picker-body {
  height: 400rpx;
  width: 100%;
  background: #FFFFFF;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  font-size: 32rpx;
  color: #1C1C1E;
}

/* Taste Rating */
.taste-buttons {
  display: flex;
  gap: 20rpx;
}

.taste-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #F2F2F7;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.taste-btn:active {
  opacity: 0.8;
}

.taste-btn-good-active {
  background: rgba(52, 199, 89, 0.12);
  border-color: rgba(52, 199, 89, 0.3);
}

.taste-btn-bad-active {
  background: rgba(255, 59, 48, 0.12);
  border-color: rgba(255, 59, 48, 0.3);
}

.taste-btn-emoji {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.taste-btn-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1C1C1E;
}

/* Bad Reasons */
.bad-reasons-section {
  margin-top: 8rpx;
}

.bad-reason-chips {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.bad-reason-chip {
  padding: 16rpx 32rpx;
  background: #FFFFFF;
  border: 1.5rpx solid #E5E5EA;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #3A3A3C;
}

.bad-reason-chip.selected {
  background: rgba(255, 59, 48, 0.12);
  border-color: #FF3B30;
  color: #FF3B30;
}

.bad-reason-chip:active {
  opacity: 0.7;
}

/* Filter Cup */
.filter-cup-row {
  display: flex;
}

.filter-cup-select {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  border: 0.5rpx solid #D1D1D6;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1C1C1E;
  background: #FFFFFF;
}

.filter-cup-select:active {
  background: #F2F2F7;
}

.brew-param-arrow {
  font-size: 28rpx;
  color: #C7C7CC;
}
