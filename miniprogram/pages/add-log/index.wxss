.page-add {
  height: 100vh;
}

/* Roast Bean Picker */
.roast-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.roast-row .form-label {
  margin-bottom: 0;
  flex-shrink: 0;
}

.roast-beans {
  display: flex;
  gap: 16rpx;
}

.roast-bean {
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.roast-img {
  width: 56rpx;
  height: 56rpx;
  filter: grayscale(100%);
  opacity: 0.5;
  transition: filter 0.2s, opacity 0.2s;
}

.roast-bean.active .roast-img {
  filter: grayscale(0%);
  opacity: 1;
}

.roast-label {
  font-size: 26rpx;
  color: #8B7355;
  flex-shrink: 0;
  min-width: 56rpx;
  text-align: right;
  margin-left: auto;
}

/* Glass Segmented Control (iOS 26 style) */
.glass-segmented {
  display: flex;
  position: relative;
  background: rgba(232, 221, 208, 0.4);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-radius: 20rpx;
  border: 0.5rpx solid rgba(255, 255, 255, 0.6);
}

.glass-indicator {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 33.33%;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(74, 44, 42, 0.1), 0 1rpx 2rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 0;
}

.glass-segment {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx 0;
  position: relative;
  z-index: 1;
  color: #8B7355;
  transition: color 0.25s;
}

.glass-segment.active {
  color: #4A2C2A;
  font-weight: 600;
}

.glass-segment-icon {
  font-size: 32rpx;
}

.glass-segment-label {
  font-size: 26rpx;
  font-weight: 500;
}

/* Collapsible Sections */
.collapsible-toggle {
  display: flex;
  align-items: center;
}

.collapse-arrow {
  font-size: 22rpx;
  color: #C4A882;
  margin-left: auto;
  transition: transform 0.3s ease;
}

.collapse-arrow.expanded {
  transform: rotate(180deg);
}

.collapsible-body {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: max-height 0.3s ease, opacity 0.25s ease;
}

.collapsible-body.expanded {
  max-height: 500rpx;
  opacity: 1;
}

/* Glass Rating Segmented */
.glass-rating {
  flex: 1;
  margin-left: 12rpx;
}

.glass-rating-track {
  position: relative;
  display: flex;
  background: rgba(232, 221, 208, 0.4);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-radius: 16rpx;
  border: 0.5rpx solid rgba(255, 255, 255, 0.6);
  overflow: hidden;
}

.glass-rating-slider {
  position: absolute;
  top: 0;
  left: 0;
  bottom: 0;
  background: rgba(196, 168, 130, 0.35);
  backdrop-filter: saturate(200%) blur(24px);
  -webkit-backdrop-filter: saturate(200%) blur(24px);
  border-radius: 16rpx;
  transition: width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 0;
}

.glass-rating-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  position: relative;
  z-index: 1;
  border-right: 0.5rpx solid rgba(196, 168, 130, 0.2);
}

.glass-rating-option:last-child {
  border-right: none;
}

.glass-rating-num {
  font-size: 24rpx;
  color: transparent;
  font-weight: 600;
  position: relative;
  z-index: 2;
}

.glass-rating-num.visible {
  color: #4A2C2A;
}

/* Param List— tappable rows */
.param-list {
  border-radius: 12rpx;
  overflow: hidden;
  border: 0.5rpx solid #E8DDD0;
}

.param-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #FEFCF9;
  border-bottom: 0.5rpx solid #F0EBE3;
}

.param-cell:last-child {
  border-bottom: none;
}

.param-cell:active {
  background: #F5EDE3;
}

.param-cell-label {
  font-size: 28rpx;
  color: #4A2C2A;
  font-weight: 500;
}

.param-cell-right {
  display: flex;
  align-items: center;
}

.param-cell-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D1810;
  margin-right: 8rpx;
}

.param-cell-unit {
  font-size: 24rpx;
  color: #8B7355;
  margin-right: 12rpx;
}

.param-cell-arrow {
  font-size: 22rpx;
  color: #C4A882;
}

/* Two-column param grid */
.param-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}

.param-grid-cell {
  width: 50%;
  box-sizing: border-box;
  padding: 8rpx;
}

.param-grid-inner {
  background: #FEFCF9;
  border: 0.5rpx solid #E8DDD0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.param-grid-inner:active {
  background: #F5EDE3;
}

.param-grid-label {
  font-size: 22rpx;
  color: #8B7355;
  margin-bottom: 8rpx;
  display: block;
}

.param-grid-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D1810;
  display: block;
}

.param-grid-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: #8B7355;
}

/* Picker */
.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.placeholder {
  color: #C4B5A0;
}

.picker-arrow {
  color: #C4A882;
  font-size: 24rpx;
}

/* Submit */
.submit-wrap {
  padding: 32rpx;
}

.safe-bottom {
  height: 60rpx;
}

/* ========== Scroll Wheel Picker Bottom Sheet ========== */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.picker-sheet {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 0.5rpx solid #F0EBE3;
}

.picker-cancel {
  font-size: 30rpx;
  color: #8B7355;
  padding: 8rpx 16rpx;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #4A2C2A;
}

.picker-confirm {
  font-size: 30rpx;
  color: #6F4E37;
  font-weight: 600;
  padding: 8rpx 16rpx;
}

.picker-body {
  height: 400rpx;
  width: 100%;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  font-size: 32rpx;
  color: #2D1810;
}
