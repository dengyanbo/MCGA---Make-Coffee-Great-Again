.brew-page {
  height: 100vh;
  background: #F2F2F7;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.fade-in {
  animation: brewFadeIn 0.4s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
}

@keyframes brewFadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.brew-header {
  padding: 120rpx 40rpx 40rpx;
  text-align: center;
}

.brew-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1C1C1E;
}

/* State A — Method selection */
.brew-state-a {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}

.brew-methods {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 40rpx;
}

.brew-method-card {
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(20px);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 0.5rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.brew-method-card:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.brew-method-disabled { opacity: 0.5; }
.brew-method-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.brew-method-label { font-size: 36rpx; font-weight: 600; color: #1C1C1E; }
.brew-method-desc { font-size: 24rpx; color: #8E8E93; margin-top: 4rpx; }
.brew-method-soon {
  font-size: 22rpx; color: #AEAEB2; background: #F2F2F7;
  padding: 4rpx 16rpx; border-radius: 12rpx; margin-top: 8rpx;
}

/* State B — Params */
.brew-state-b { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

.brew-param-card {
  display: flex; align-items: center; justify-content: space-between;
  background: #FFFFFF; margin: 0 40rpx 16rpx; padding: 28rpx 32rpx; border-radius: 16rpx;
}
.brew-param-card:active { background: #F2F2F7; }
.brew-param-label { font-size: 28rpx; color: #1C1C1E; font-weight: 500; }
.brew-param-right { display: flex; align-items: center; }
.brew-param-value { font-size: 28rpx; color: #3A3A3C; font-weight: 600; }
.brew-param-arrow { font-size: 32rpx; color: #C7C7CC; margin-left: 8rpx; }

.brew-technique-section { padding: 16rpx 40rpx; }

.brew-technique-seg {
  display: flex; background: rgba(118,118,128,0.12); border-radius: 16rpx;
  position: relative; overflow: hidden;
}

.brew-tech-slider {
  position: absolute; top: 4rpx; bottom: 4rpx; left: 4rpx;
  width: calc(50% - 4rpx); border-radius: 14rpx;
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  transition: transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  z-index: 0;
}

.brew-tech-option {
  flex: 1; display: flex; align-items: center; justify-content: center;
  padding: 24rpx 0; color: #8E8E93; font-size: 28rpx; font-weight: 500;
  border-radius: 16rpx; transition: color 0.3s, font-weight 0.3s;
  position: relative; z-index: 1;
}

.brew-tech-option.active {
  color: #1C1C1E; font-weight: 600;
}

/* Fixed bottom section (start button + recipe) */
.brew-bottom-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #F2F2F7;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 10;
}

.brew-start-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 40rpx 16rpx;
}

.brew-start-btn {
  width: 300rpx; height: 300rpx; border-radius: 150rpx; background: #1C1C1E;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 12rpx 48rpx rgba(0,0,0,0.2);
}

.brew-start-btn:active { opacity: 0.85; transform: scale(0.96); }

.brew-start-text {
  color: #FFFFFF; font-size: 36rpx; font-weight: 700; letter-spacing: 4rpx;
}

/* State C — Timer */
.brew-state-c {
  flex: 1; display: flex; flex-direction: column; justify-content: center;
  padding: 0 40rpx 200rpx; overflow: hidden;
}

.brew-timer-wrap { display: flex; flex-direction: column; align-items: center; }

.brew-step-display {
  text-align: center; margin-bottom: 48rpx; background: #FFFFFF;
  padding: 32rpx 40rpx; border-radius: 20rpx; width: 100%; box-sizing: border-box;
}

.brew-step-action { font-size: 44rpx; font-weight: 700; color: #1C1C1E; display: block; }
.brew-step-desc { font-size: 26rpx; color: #8E8E93; margin-top: 10rpx; display: block; }

.brew-step-pattern {
  font-size: 24rpx; color: #636366; background: #F2F2F7;
  padding: 8rpx 24rpx; border-radius: 20rpx; display: inline-block; margin-top: 16rpx;
}

.brew-paused-badge { margin-bottom: 16rpx; }
.brew-paused-badge text {
  font-size: 24rpx; color: #8E8E93; background: #E5E5EA;
  padding: 6rpx 28rpx; border-radius: 16rpx; font-weight: 600;
}

.brew-timer-display { display: flex; align-items: baseline; margin-bottom: 48rpx; }

.brew-timer-value {
  font-size: 96rpx; font-weight: 800; color: #1C1C1E; font-variant-numeric: tabular-nums;
}

.brew-timer-total { font-size: 32rpx; color: #AEAEB2; margin-left: 8rpx; }

.brew-progress-wrap { width: 100%; position: relative; padding: 0 8rpx; }

.brew-progress-bar {
  width: 100%; height: 10rpx; background: #E5E5EA; border-radius: 5rpx; overflow: hidden;
}

.brew-progress-fill {
  height: 100%; background: #8E8E93; border-radius: 5rpx; transition: width 1s linear;
}

.brew-step-markers { position: absolute; top: 0; left: 8rpx; right: 8rpx; height: 10rpx; }

.brew-step-marker {
  position: absolute; top: -4rpx; width: 3rpx; height: 18rpx;
  background: #C7C7CC; border-radius: 2rpx; transform: translateX(-50%);
}

.brew-steps-info { margin-top: 20rpx; }
.brew-step-counter { font-size: 24rpx; color: #AEAEB2; }

/* Bottom controls — fixed at bottom, full width, text only */
.brew-bottom-controls {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  display: flex;
  gap: 0;
  padding: 24rpx 40rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #F2F2F7;
}

.brew-bottom-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.brew-bottom-btn:active { opacity: 0.7; }

.brew-bottom-pause {
  background: #FFFFFF;
  color: #3A3A3C;
  margin-right: 12rpx;
}

.brew-bottom-resume {
  background: #FFFFFF;
  color: #1C1C1E;
  margin-right: 12rpx;
}

.brew-bottom-stop {
  background: #E5E5EA;
  color: #8E8E93;
}

/* Timer done */
.brew-done-wrap {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  justify-content: center; overflow: hidden;
}

.brew-done-emoji { font-size: 120rpx; margin-bottom: 32rpx; }
.brew-done-title { font-size: 40rpx; font-weight: 700; color: #1C1C1E; margin-bottom: 48rpx; }

.brew-done-btn {
  padding: 24rpx 64rpx; background: #FFFFFF; border-radius: 48rpx;
  color: #1C1C1E; font-size: 32rpx; font-weight: 600; border: 0.5rpx solid #E5E5EA;
}
.brew-done-btn:active { background: #F2F2F7; }

/* State D — Feedback */
.brew-state-d {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  justify-content: center;
  padding: 0 40rpx 200rpx; overflow: hidden;
}

.brew-feedback-title {
  font-size: 40rpx; font-weight: 700; color: #1C1C1E;
  margin-bottom: 40rpx; display: block; text-align: center;
}

.brew-feedback-buttons { display: flex; gap: 20rpx; width: 100%; }

.brew-feedback-btn {
  flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 36rpx 0; border-radius: 24rpx; gap: 12rpx; transition: all 0.25s;
}

.brew-feedback-btn:active { transform: scale(0.97); }

.brew-fb-good { background: #FFFFFF; border: 1.5rpx solid #E5E5EA; }
.brew-fb-bad { background: #F2F2F7; border: 1.5rpx solid #E5E5EA; }

.brew-fb-selected.brew-fb-good {
  background: #FFFFFF; border-color: #D1D1D6; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.brew-fb-selected.brew-fb-bad { background: #E5E5EA; border-color: #C7C7CC; }

.brew-feedback-emoji { font-size: 64rpx; }
.brew-feedback-label { font-size: 30rpx; font-weight: 600; color: #1C1C1E; }

/* Quote */
.brew-quote {
  width: 100%;
  text-align: center;
  margin-top: 24rpx;
}

.brew-quote-text {
  font-size: 26rpx;
  color: #8E8E93;
  font-style: italic;
  line-height: 1.6;
}

/* Bad reasons animated expand */
.brew-bad-expand {
  width: 100%; max-height: 0; overflow: hidden; opacity: 0;
  transition: max-height 0.4s cubic-bezier(0.25,0.1,0.25,1), opacity 0.3s ease;
}

.brew-bad-expand.expanded { max-height: 500rpx; opacity: 1; margin-top: 32rpx; }

.brew-bad-hint { font-size: 26rpx; color: #8E8E93; display: block; margin-bottom: 16rpx; }

.brew-reason-options { display: flex; gap: 12rpx; flex-wrap: wrap; }

.brew-reason-chip {
  padding: 18rpx 36rpx; background: #FFFFFF; border-radius: 32rpx;
  font-size: 28rpx; color: #3A3A3C; border: 1rpx solid #E5E5EA; transition: all 0.2s;
}

.brew-reason-chip.selected {
  background: #E5E5EA; border-color: #C7C7CC; color: #1C1C1E; font-weight: 600;
}

.brew-reason-chip:active { opacity: 0.7; }

.brew-custom-expand {
  max-height: 0; overflow: hidden; opacity: 0;
  transition: max-height 0.35s ease, opacity 0.25s ease;
}

.brew-custom-expand.expanded { max-height: 120rpx; opacity: 1; margin-top: 16rpx; }

.brew-custom-input {
  width: 100%; height: 80rpx; border: 0.5rpx solid #D1D1D6; border-radius: 12rpx;
  padding: 0 24rpx; font-size: 28rpx; color: #1C1C1E; background: #FFFFFF; box-sizing: border-box;
}

/* Submit button */
.brew-submit-wrap {
  width: 100%; margin-top: 36rpx; opacity: 0; transition: opacity 0.3s ease;
}

.brew-submit-wrap.visible { opacity: 1; }

.brew-submit-btn {
  width: 100%; height: 88rpx; display: flex; align-items: center; justify-content: center;
  background: #1C1C1E; border-radius: 48rpx; color: #FFFFFF; font-size: 32rpx; font-weight: 600;
}

.brew-submit-btn:active { opacity: 0.85; }
.brew-submit-btn.disabled { opacity: 0.5; }

/* Skip FAB — round, fixed bottom-left */
.brew-skip-fab {
  position: fixed;
  left: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: #E5E5EA;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 50;
}

.brew-skip-fab:active { opacity: 0.7; }

.brew-skip-text {
  font-size: 24rpx;
  color: #636366;
  font-weight: 600;
}

/* Back button */
.brew-back { position: fixed; top: 100rpx; left: 32rpx; z-index: 10; }
.brew-back-text { font-size: 48rpx; color: #8E8E93; font-weight: 300; line-height: 1; }
.brew-back:active { opacity: 0.6; }

/* Inline input (same height as param cards) */
.brew-param-input-right {
  flex: 1; display: flex; align-items: center; gap: 8rpx; margin-left: 16rpx;
}
.brew-inline-input {
  flex: 1; height: 56rpx; border: 0.5rpx solid #D1D1D6; border-radius: 10rpx;
  padding: 0 16rpx; font-size: 26rpx; color: #1C1C1E; background: #FAFAFA; box-sizing: border-box;
}
.brew-inline-confirm {
  width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center;
  background: #1C1C1E; border-radius: 10rpx; color: #FFFFFF; font-size: 28rpx; font-weight: 600; flex-shrink: 0;
}
.brew-inline-confirm:active { opacity: 0.85; }

.brew-inline-cancel {
  width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center;
  background: #E5E5EA; border-radius: 10rpx; color: #8E8E93; font-size: 28rpx; font-weight: 600; flex-shrink: 0;
}
.brew-inline-cancel:active { opacity: 0.7; }

/* Recipe selection */
.brew-recipe-section { padding: 0 40rpx; }

.brew-recipe-label { margin-bottom: 12rpx; display: block; }

.brew-recipe-scroll { white-space: nowrap; width: 100%; }

.brew-recipe-list { display: inline-flex; gap: 12rpx; }

.brew-recipe-chip {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 18rpx 32rpx; background: #FFFFFF; border-radius: 32rpx;
  font-size: 28rpx; color: #3A3A3C; border: 1rpx solid #E5E5EA; transition: all 0.2s;
  flex-shrink: 0;
}

.brew-recipe-chip.selected {
  background: #1C1C1E; color: #FFFFFF; border-color: #1C1C1E; font-weight: 600;
}

.brew-recipe-chip:active { opacity: 0.7; }

.brew-recipe-loading {
  font-size: 24rpx; color: #8E8E93; padding: 16rpx 40rpx;
}

/* Picker (shared) */
.picker-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 1000; display: flex; align-items: flex-end;
}

.picker-sheet { width: 100%; background: #F2F2F7; border-radius: 24rpx 24rpx 0 0; overflow: hidden; }

.picker-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 32rpx; border-bottom: 0.5rpx solid #E5E5EA; background: #FFFFFF;
}

.picker-cancel { font-size: 30rpx; color: #8E8E93; padding: 8rpx 16rpx; }
.picker-title { font-size: 32rpx; font-weight: 600; color: #1C1C1E; }
.picker-confirm { font-size: 30rpx; color: #3A3A3C; font-weight: 600; padding: 8rpx 16rpx; }

.picker-body { height: 400rpx; width: 100%; background: #FFFFFF; }

.picker-item {
  display: flex; align-items: center; justify-content: center;
  height: 80rpx; font-size: 32rpx; color: #1C1C1E;
}
