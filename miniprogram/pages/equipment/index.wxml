<view class="page-equipment">
  <view wx:if="{{loading}}" class="loading-wrap" style="padding-top: 200rpx;">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
    <!-- Beans -->
    <view class="card">
      <view class="section-title">
        <text class="icon">☕</text>
        <text>咖啡豆</text>
      </view>
      <view class="equip-list">
        <view class="equip-item" wx:for="{{beans}}" wx:key="name">
          <view class="equip-bean-info">
            <text class="equip-name">{{item.name}}</text>
            <text wx:if="{{item.roastLevel}}" class="equip-roast-tag">{{roastLabels[item.roastLevel] || ''}}</text>
          </view>
          <view class="equip-delete" data-idx="{{index}}" bindtap="onDeleteBean">
            <text>×</text>
          </view>
        </view>
        <view wx:if="{{beans.length === 0}}" class="equip-empty">
          <text>暂无咖啡豆</text>
        </view>
      </view>
      <view class="equip-add-row">
        <input class="equip-add-input" placeholder="添加咖啡豆" value="{{newBean}}" bindinput="onNewBeanInput" bindconfirm="onAddBean" />
        <view class="equip-add-btn" bindtap="onAddBean"><text>+</text></view>
      </view>
      <view class="equip-roast-row">
        <text class="equip-roast-label">烘焙度</text>
        <view class="equip-roast-beans">
          <view class="equip-roast-bean {{newBeanRoastIndex >= 0 ? 'active' : ''}}" data-level="{{0}}" bindtap="onPickNewBeanRoast">
            <image class="equip-roast-img" src="/images/roast_levels/roast_light.png" mode="aspectFit" /></view>
          <view class="equip-roast-bean {{newBeanRoastIndex >= 1 ? 'active' : ''}}" data-level="{{1}}" bindtap="onPickNewBeanRoast">
            <image class="equip-roast-img" src="/images/roast_levels/roast_medium_light.png" mode="aspectFit" /></view>
          <view class="equip-roast-bean {{newBeanRoastIndex >= 2 ? 'active' : ''}}" data-level="{{2}}" bindtap="onPickNewBeanRoast">
            <image class="equip-roast-img" src="/images/roast_levels/roast_medium.png" mode="aspectFit" /></view>
          <view class="equip-roast-bean {{newBeanRoastIndex >= 3 ? 'active' : ''}}" data-level="{{3}}" bindtap="onPickNewBeanRoast">
            <image class="equip-roast-img" src="/images/roast_levels/roast_medium_dark.png" mode="aspectFit" /></view>
          <view class="equip-roast-bean {{newBeanRoastIndex >= 4 ? 'active' : ''}}" data-level="{{4}}" bindtap="onPickNewBeanRoast">
            <image class="equip-roast-img" src="/images/roast_levels/roast_dark.png" mode="aspectFit" /></view>
        </view>
        <text class="equip-roast-text">{{newBeanRoastIndex >= 0 ? roastLevels[newBeanRoastIndex] : ''}}</text>
      </view>
    </view>

    <!-- Grinders -->
    <view class="card">
      <view class="section-title">
        <text class="icon">⚙️</text>
        <text>磨豆机</text>
      </view>
      <view class="equip-list">
        <view class="equip-item" wx:for="{{grinders}}" wx:key="*this">
          <text class="equip-name">{{item}}</text>
          <view class="equip-delete" data-idx="{{index}}" bindtap="onDeleteGrinder">
            <text>×</text>
          </view>
        </view>
        <view wx:if="{{grinders.length === 0}}" class="equip-empty">
          <text>暂无磨豆机</text>
        </view>
      </view>
      <view class="equip-add-row">
        <input class="equip-add-input" placeholder="添加磨豆机" value="{{newGrinder}}" bindinput="onNewGrinderInput" bindconfirm="onAddGrinder" />
        <view class="equip-add-btn" bindtap="onAddGrinder"><text>+</text></view>
      </view>
    </view>

    <!-- Filter Cups -->
    <view class="card">
      <view class="section-title">
        <text class="icon">🫗</text>
        <text>滤杯</text>
      </view>
      <view class="equip-list">
        <view class="equip-item" wx:for="{{filterCups}}" wx:key="*this">
          <text class="equip-name">{{item}}</text>
          <view class="equip-delete" data-idx="{{index}}" bindtap="onDeleteFilterCup">
            <text>×</text>
          </view>
        </view>
        <view wx:if="{{filterCups.length === 0}}" class="equip-empty">
          <text>暂无滤杯</text>
        </view>
      </view>
      <view class="equip-add-row">
        <input class="equip-add-input" placeholder="添加滤杯" value="{{newFilterCup}}" bindinput="onNewFilterCupInput" bindconfirm="onAddFilterCup" />
        <view class="equip-add-btn" bindtap="onAddFilterCup"><text>+</text></view>
      </view>
    </view>
  </block>

  <view class="safe-bottom"></view>
</view>
