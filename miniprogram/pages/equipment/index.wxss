.page-equipment {
  min-height: 100vh;
  padding-top: 16rpx;
}

.equip-list {
  margin-bottom: 20rpx;
}

.equip-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 0.5rpx solid #F2F2F7;
}

.equip-item:last-child {
  border-bottom: none;
}

.equip-name {
  font-size: 28rpx;
  color: #1C1C1E;
  flex: 1;
}

.equip-delete {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FF3B30;
  font-size: 36rpx;
  font-weight: 300;
  border-radius: 28rpx;
  flex-shrink: 0;
}

.equip-delete:active {
  background: rgba(255, 59, 48, 0.1);
}

.equip-empty {
  padding: 24rpx 0;
}

.equip-empty text {
  font-size: 26rpx;
  color: #AEAEB2;
}

.equip-add-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding-top: 16rpx;
  border-top: 0.5rpx solid #F2F2F7;
}

.equip-add-input {
  flex: 1;
  height: 72rpx;
  border: 0.5rpx solid #D1D1D6;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #1C1C1E;
  background: #FAFAFA;
  box-sizing: border-box;
}

.equip-add-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1C1C1E;
  border-radius: 12rpx;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 300;
  flex-shrink: 0;
}

.equip-add-btn:active {
  opacity: 0.85;
}

.safe-bottom {
  height: 60rpx;
}
