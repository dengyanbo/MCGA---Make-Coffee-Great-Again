<wxs src="../../utils/filters.wxs" module="f" />

<view class="page-home">
  <!-- Header -->
  <view class="header">
    <view class="header-left">
      <text class="header-title">☕ {{nickname ? nickname + '的咖啡' : 'MCGA Coffee'}}</text>
      <text class="header-subtitle">记录每一杯的美好</text>
    </view>
    <view class="header-right" bindtap="onGoStats">
      <text class="stats-btn">📊</text>
    </view>
  </view>

  <!-- Guest State -->
  <view wx:if="{{isGuest}}" class="empty-state">
    <text class="empty-icon">☕</text>
    <text class="empty-title">欢迎使用 MCGA Coffee</text>
    <text class="empty-desc">登录后可保存记录并查看历史数据</text>
    <view class="guest-login-btn" bindtap="onGoLogin">
      <text>登录账号</text>
    </view>
  </view>

  <!-- Logged-in content -->
  <block wx:else>
    <!-- Stats Summary Card -->
    <view wx:if="{{stats && stats.totalBrews > 0}}" class="stats-summary-card">
      <view class="stats-row">
        <view class="stats-item">
          <text class="stats-value">{{stats.totalBrews}}</text>
          <text class="stats-label">总冲煮</text>
        </view>
        <view class="stats-item">
          <text class="stats-value">{{stats.goodRate || '0%'}}</text>
          <text class="stats-label">好喝率</text>
        </view>
      </view>
      <view wx:if="{{stats.topBadReasons && stats.topBadReasons.length > 0}}" class="stats-bad-reasons">
        <text class="stats-bad-label">常见问题：</text>
        <text class="tag tag-reason" wx:for="{{stats.topBadReasons}}" wx:key="*this">{{f.getBadReason(item)}}</text>
      </view>
    </view>

    <!-- Filter Tabs -->
    <scroll-view scroll-x class="filter-tabs-scroll">
      <view class="filter-tabs">
        <view class="filter-tab {{activeFilter === item.key ? 'active' : ''}}"
          wx:for="{{filterTabs}}" wx:key="key"
          data-key="{{item.key}}" bindtap="onFilterChange">
          <text>{{item.label}}</text>
        </view>
      </view>
    </scroll-view>

    <!-- Log List -->
    <view wx:if="{{!isEmpty}}" class="log-list">
      <view class="log-card" wx:for="{{logs}}" wx:key="_id"
        data-id="{{item._id}}" bindtap="onTapLog">
        <view class="log-card-top">
          <view class="log-card-info">
            <text class="bean-name">{{item.beanName || '冲煮记录'}}</text>
            <view class="tags">
              <text class="tag tag-method">{{f.getBrewMethod(item.brewMethod)}}</text>
              <text wx:if="{{item.roastLevel}}" class="tag tag-roast">{{f.getRoast(item.roastLevel)}}</text>
              <text wx:if="{{item.brewTechnique}}" class="tag tag-method">{{f.getBrewTechnique(item.brewTechnique)}}</text>
              <text wx:if="{{item.taste === 'bad' && item.badReasons}}" class="tag tag-reason" wx:for="{{item.badReasons}}" wx:for-item="reason" wx:key="*this">{{f.getBadReason(reason)}}</text>
            </view>
          </view>
          <view class="log-card-taste">
            <text wx:if="{{item.taste === 'good'}}" class="taste-label taste-label-good">好喝</text>
            <text wx:elif="{{item.taste === 'bad'}}" class="taste-label taste-label-bad">难喝</text>
            <text wx:elif="{{item.overall}}" class="score-value-old">{{item.overall}}</text>
          </view>
        </view>
        <view class="log-card-bottom">
          <text class="log-params">{{item.coffeeDose ? item.coffeeDose + 'g · ' : ''}}{{item.waterAmount ? item.waterAmount + 'ml · ' : ''}}{{item.waterTemp ? item.waterTemp + '°C' : ''}}</text>
          <text class="log-date">{{f.formatDate(item.createdAt)}}</text>
        </view>
      </view>
    </view>

    <!-- Error State -->
    <view wx:if="{{loadError && !loading}}" class="empty-state">
      <text class="empty-icon">⚠️</text>
      <text class="empty-title">加载失败</text>
      <text class="empty-desc">无法连接服务器，请检查网络后重试</text>
      <view class="retry-btn" bindtap="onRetry">
        <text>🔄 重新加载</text>
      </view>
    </view>

    <!-- Empty State -->
    <view wx:elif="{{isEmpty && !loading}}" class="empty-state">
      <text class="empty-icon">☕</text>
      <text class="empty-title">还没有咖啡记录</text>
      <text class="empty-desc">点击下方按钮，开始记录你的第一杯咖啡</text>
    </view>

    <!-- Loading -->
    <view wx:if="{{loading}}" class="loading-wrap">
      <text class="loading-text">加载中...</text>
    </view>

    <!-- Show More -->
    <view wx:if="{{hasMore && !loading && logs.length > 0}}" class="show-more-wrap">
      <view class="show-more-btn" bindtap="onShowMore">
        <text>显示更多</text>
      </view>
    </view>

    <!-- No more -->
    <view wx:if="{{!hasMore && logs.length > 0}}" class="loading-wrap">
      <text class="loading-text">没有更多了</text>
    </view>
  </block>

  <!-- FABs -->
  <view class="fab fab-right" bindtap="onAddLog">
    <text class="fab-icon">+</text>
  </view>
  <view class="fab fab-left" bindtap="onGoBrew">
    <text class="fab-text">Brew</text>
  </view>
</view>
