.page-home {
  padding-bottom: 120rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1C1C1E;
  display: block;
}

.header-subtitle {
  font-size: 24rpx;
  color: #8E8E93;
  margin-top: 4rpx;
  display: block;
}

.header-right {
  display: flex;
  align-items: center;
}

.stats-btn {
  font-size: 48rpx;
  padding: 12rpx;
}

/* Stats Summary Card */
.stats-summary-card {
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(20px);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 32rpx 24rpx;
  border: 0.5rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-value {
  font-size: 48rpx;
  font-weight: 800;
  color: #1C1C1E;
  line-height: 1;
}

.stats-label {
  font-size: 22rpx;
  color: #8E8E93;
  margin-top: 8rpx;
}

.stats-bad-reasons {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 0.5rpx solid rgba(0,0,0,0.06);
}

.stats-bad-label {
  font-size: 22rpx;
  color: #8E8E93;
}

/* Filter Tabs */
.filter-tabs-scroll {
  white-space: nowrap;
  margin: 0 32rpx 16rpx;
}

.filter-tabs {
  display: inline-flex;
  gap: 12rpx;
}

.filter-tab {
  display: inline-flex;
  padding: 12rpx 28rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #8E8E93;
  font-weight: 500;
}

.filter-tab.active {
  background: #1C1C1E;
  color: #FFFFFF;
}

.filter-tab:active {
  opacity: 0.7;
}

/* Log Cards */
.log-list {
  padding: 0 0 40rpx;
}

.log-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin: 0 32rpx 20rpx;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04);
}

.log-card:active {
  opacity: 0.92;
}

.log-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.log-card-info {
  flex: 1;
  min-width: 0;
}

.bean-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1C1E;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tags {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.log-card-taste {
  margin-left: 24rpx;
  display: flex;
  align-items: center;
}

.taste-label {
  font-size: 24rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  line-height: 1.4;
}

.taste-label-good {
  color: #1C1C1E;
  background: #FFFFFF;
  border: 0.5rpx solid #E5E5EA;
}

.taste-label-bad {
  color: #8E8E93;
  background: #F2F2F7;
  border: 0.5rpx solid #E5E5EA;
}

.score-value-old {
  font-size: 44rpx;
  font-weight: 700;
  color: #8E8E93;
  line-height: 1;
}

.log-card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F2F2F7;
}

.log-params {
  font-size: 24rpx;
  color: #8E8E93;
}

.log-date {
  font-size: 22rpx;
  color: #AEAEB2;
}

/* Show More */
.show-more-wrap {
  display: flex;
  justify-content: center;
  padding: 20rpx 32rpx 40rpx;
}

.show-more-btn {
  padding: 20rpx 64rpx;
  background: #FFFFFF;
  border-radius: 40rpx;
  color: #3A3A3C;
  font-size: 28rpx;
  font-weight: 500;
}

.show-more-btn:active {
  opacity: 0.7;
}

/* Guest Login */
.guest-login-btn {
  margin-top: 32rpx;
  padding: 20rpx 64rpx;
  background: #1C1C1E;
  border-radius: 40rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
}

.guest-login-btn:active {
  opacity: 0.85;
}

/* FABs */
.fab {
  position: fixed;
  bottom: 60rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
}

.fab:active {
  opacity: 0.85;
}

.fab-right {
  right: 40rpx;
  background: #1C1C1E;
}

.fab-left {
  left: 40rpx;
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(20px);
  border: 0.5rpx solid rgba(0,0,0,0.08);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.1);
}

.fab-icon {
  color: #FFFFFF;
  font-size: 56rpx;
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
}

.fab-text {
  color: #1C1C1E;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}
