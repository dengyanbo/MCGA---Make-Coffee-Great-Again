.page-home {
  padding-bottom: 120rpx;
}

/* Header — iOS large title style */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1C1C1E;
  display: block;
}

.header-subtitle {
  font-size: 24rpx;
  color: #8E8E93;
  margin-top: 4rpx;
  display: block;
}

.header-right {
  display: flex;
  align-items: center;
}

.stats-btn {
  font-size: 48rpx;
  padding: 12rpx;
}

/* Log Cards */
.log-list {
  padding: 0 0 40rpx;
}

.log-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin: 0 32rpx 20rpx;
  box-shadow: none;
}

.log-card:active {
  opacity: 0.92;
}

.log-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.log-card-info {
  flex: 1;
  min-width: 0;
}

.bean-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1C1E;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tags {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.log-card-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 24rpx;
  min-width: 80rpx;
}

.score-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #1C1C1E;
  line-height: 1;
}

.score-label {
  font-size: 20rpx;
  color: #8E8E93;
  margin-top: 4rpx;
}

.log-card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F2F2F7;
}

.log-params {
  font-size: 24rpx;
  color: #8E8E93;
}

.log-date {
  font-size: 22rpx;
  color: #AEAEB2;
}

/* Show More Button */
.show-more-wrap {
  display: flex;
  justify-content: center;
  padding: 20rpx 32rpx 40rpx;
}

.show-more-btn {
  padding: 20rpx 64rpx;
  background: #FFFFFF;
  border-radius: 40rpx;
  color: #3A3A3C;
  font-size: 28rpx;
  font-weight: 500;
}

.show-more-btn:active {
  opacity: 0.7;
}

/* Guest Login Button */
.guest-login-btn {
  margin-top: 32rpx;
  padding: 20rpx 64rpx;
  background: #1C1C1E;
  border-radius: 40rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
}

.guest-login-btn:active {
  opacity: 0.85;
}

/* Floating Add Button */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  background: #1C1C1E;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
}

.fab:active {
  opacity: 0.85;
}

.fab-icon {
  color: #FFFFFF;
  font-size: 56rpx;
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
}
