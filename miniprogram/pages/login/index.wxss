.page-login {
  min-height: 100vh;
  background: linear-gradient(180deg, #4A2C2A 0%, #6F4E37 50%, #FFF8F0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-bg {
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.login-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 80rpx 48rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 16rpx 64rpx rgba(74, 44, 42, 0.2);
}

.login-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.login-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #4A2C2A;
  letter-spacing: 4rpx;
}

.login-subtitle {
  font-size: 24rpx;
  color: #8B7355;
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #6F4E37;
  margin-top: 48rpx;
  text-align: center;
  line-height: 1.6;
}

.login-btn {
  display: flex !important;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100% !important;
  height: 96rpx;
  background: linear-gradient(135deg, #07C160, #06AD56) !important;
  color: #FFFFFF !important;
  border-radius: 48rpx !important;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 48rpx;
  letter-spacing: 2rpx;
}

.login-btn:active {
  opacity: 0.85;
}

.login-btn[disabled] {
  opacity: 0.6;
}

.login-btn-icon {
  font-size: 36rpx;
}

.login-hint {
  font-size: 22rpx;
  color: #C4A882;
  margin-top: 32rpx;
  text-align: center;
}
