.page-login {
  min-height: 100vh;
  background: #F2F2F7;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Custom Navigation Bar */
.login-custom-nav {
  width: 100%;
  background: #F2F2F7;
}

.login-nav-inner {
  display: flex;
  align-items: center;
  position: relative;
}

.login-nav-back {
  display: flex;
  align-items: center;
  padding-left: 16rpx;
  padding-right: 40rpx;
  z-index: 1;
}

.login-nav-back:active { opacity: 0.5; }

.login-nav-arrow {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #000;
  border-top: 4rpx solid #000;
  transform: rotate(-45deg);
}

.login-bg {
  width: 100%;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.login-card {
  width: 100%;
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(30px);
  border-radius: 32rpx;
  padding: 80rpx 48rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 0.5rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 8rpx 48rpx rgba(0,0,0,0.08);
}

.login-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.login-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #1C1C1E;
  letter-spacing: 4rpx;
}

.login-subtitle {
  font-size: 24rpx;
  color: #8E8E93;
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #3A3A3C;
  margin-top: 48rpx;
  text-align: center;
  line-height: 1.6;
}

.login-btn {
  display: flex !important;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100% !important;
  height: 96rpx;
  background: #FFFFFF !important;
  color: #1C1C1E !important;
  border-radius: 16rpx !important;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 48rpx;
  letter-spacing: 2rpx;
  border: 0.5rpx solid #D1D1D6 !important;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.login-btn:active {
  background: #E5E5EA !important;
}

.login-btn[disabled] {
  opacity: 0.45;
}

.login-btn-icon {
  font-size: 36rpx;
}

.cancel-btn {
  display: flex !important;
  align-items: center;
  justify-content: center;
  width: 100% !important;
  height: 96rpx;
  background: #F2F2F7 !important;
  color: #8E8E93 !important;
  border-radius: 16rpx !important;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 20rpx;
  letter-spacing: 2rpx;
  border: none !important;
}

.cancel-btn:active {
  background: #E5E5EA !important;
}

.login-hint {
  font-size: 22rpx;
  color: #AEAEB2;
  margin-top: 32rpx;
  text-align: center;
}

/* Logged-in state */
.login-subtitle-status {
  font-size: 28rpx;
  color: #34C759;
  margin-top: 12rpx;
  font-weight: 600;
}

.nickname-section {
  width: 100%;
  margin-top: 48rpx;
}

.nickname-label {
  font-size: 26rpx;
  color: #8E8E93;
  margin-bottom: 12rpx;
  display: block;
}

.nickname-input {
  width: 100%;
  height: 80rpx;
  border: 0.5rpx solid #D1D1D6;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1C1C1E;
  background: #FFFFFF;
  box-sizing: border-box;
}

.continue-btn {
  display: flex !important;
  align-items: center;
  justify-content: center;
  width: 100% !important;
  height: 96rpx;
  background: #FFFFFF !important;
  color: #1C1C1E !important;
  border-radius: 16rpx !important;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 48rpx;
  letter-spacing: 2rpx;
  border: 0.5rpx solid #D1D1D6 !important;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.continue-btn:active {
  background: #E5E5EA !important;
}

.logout-btn {
  display: flex !important;
  align-items: center;
  justify-content: center;
  width: 100% !important;
  height: 96rpx;
  background: #F2F2F7 !important;
  color: #FF3B30 !important;
  border: none !important;
  border-radius: 16rpx !important;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 20rpx;
  letter-spacing: 2rpx;
}

.logout-btn:active {
  background: #E5E5EA !important;
}
