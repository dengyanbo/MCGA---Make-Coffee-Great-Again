.page-login {
  min-height: 100vh;
  background: #F2F2F7;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-bg {
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.login-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 80rpx 48rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.login-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.login-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #1C1C1E;
  letter-spacing: 4rpx;
}

.login-subtitle {
  font-size: 24rpx;
  color: #8E8E93;
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #3A3A3C;
  margin-top: 48rpx;
  text-align: center;
  line-height: 1.6;
}

.login-btn {
  display: flex !important;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100% !important;
  height: 96rpx;
  background: #07C160 !important;
  color: #FFFFFF !important;
  border-radius: 48rpx !important;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 48rpx;
  letter-spacing: 2rpx;
}

.login-btn:active {
  opacity: 0.85;
}

.login-btn[disabled] {
  opacity: 0.6;
}

.login-btn-icon {
  font-size: 36rpx;
}

.login-hint {
  font-size: 22rpx;
  color: #AEAEB2;
  margin-top: 32rpx;
  text-align: center;
}

/* Logged-in state */
.login-subtitle-status {
  font-size: 28rpx;
  color: #34C759;
  margin-top: 12rpx;
  font-weight: 600;
}

.nickname-section {
  width: 100%;
  margin-top: 48rpx;
}

.nickname-label {
  font-size: 26rpx;
  color: #8E8E93;
  margin-bottom: 12rpx;
  display: block;
}

.nickname-input {
  width: 100%;
  height: 80rpx;
  border: 0.5rpx solid #D1D1D6;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1C1C1E;
  background: #FFFFFF;
  box-sizing: border-box;
}

.continue-btn {
  display: flex !important;
  align-items: center;
  justify-content: center;
  width: 100% !important;
  height: 96rpx;
  background: #1C1C1E !important;
  color: #FFFFFF !important;
  border-radius: 48rpx !important;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 48rpx;
  letter-spacing: 2rpx;
}

.continue-btn:active {
  opacity: 0.85;
}

.logout-btn {
  display: flex !important;
  align-items: center;
  justify-content: center;
  width: 100% !important;
  height: 96rpx;
  background: #FFFFFF !important;
  color: #FF3B30 !important;
  border: 0.5rpx solid #FF3B30 !important;
  border-radius: 48rpx !important;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 24rpx;
  letter-spacing: 2rpx;
}

.logout-btn:active {
  opacity: 0.7;
}
