.onboarding-page {
  min-height: 100vh;
  background: #F2F2F7;
}

.onboarding-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.3);
  backdrop-filter: blur(20px);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.onboarding-overlay.visible {
  opacity: 1;
}

.onboarding-card {
  width: calc(100% - 80rpx);
  max-width: 640rpx;
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(30px);
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  border: 0.5rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 8rpx 48rpx rgba(0,0,0,0.12);
  transform: translateY(40rpx);
  transition: transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.onboarding-card.slide-up {
  transform: translateY(0);
}

.step-indicator {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 40rpx;
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background: #D1D1D6;
  transition: background 0.3s, width 0.3s;
}

.step-dot.active {
  background: #1C1C1E;
  width: 32rpx;
}

.onboarding-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1C1C1E;
  display: block;
  text-align: center;
}

.onboarding-desc {
  font-size: 26rpx;
  color: #8E8E93;
  display: block;
  text-align: center;
  margin-top: 8rpx;
  margin-bottom: 32rpx;
}

.onboarding-input-row {
  display: flex;
  gap: 12rpx;
}

.onboarding-input {
  flex: 1;
  height: 80rpx;
  border: 0.5rpx solid #D1D1D6;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1C1C1E;
  background: rgba(255,255,255,0.8);
  box-sizing: border-box;
}

.onboarding-add-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1C1C1E;
  border-radius: 12rpx;
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: 300;
}

.onboarding-add-btn:active {
  opacity: 0.85;
}

.onboarding-items {
  margin-top: 24rpx;
  max-height: 320rpx;
  overflow-y: auto;
}

.onboarding-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: rgba(255,255,255,0.6);
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.onboarding-item-text {
  font-size: 28rpx;
  color: #1C1C1E;
  font-weight: 500;
}

.onboarding-item-remove {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FF3B30;
  font-size: 32rpx;
}

.onboarding-empty {
  padding: 40rpx 0;
  text-align: center;
}

.onboarding-empty-text {
  font-size: 24rpx;
  color: #AEAEB2;
}

.onboarding-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.onboarding-skip {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(142,142,147,0.12);
  border-radius: 48rpx;
  color: #8E8E93;
  font-size: 30rpx;
  font-weight: 500;
}

.onboarding-skip:active {
  opacity: 0.7;
}

.onboarding-next {
  flex: 2;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1C1C1E;
  border-radius: 48rpx;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
}

.onboarding-next:active {
  opacity: 0.85;
}

.onboarding-next.disabled {
  opacity: 0.5;
}
