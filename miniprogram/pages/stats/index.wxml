<wxs src="../../utils/filters.wxs" module="f" />

<view wx:if="{{loading}}" class="loading-wrap" style="padding-top: 200rpx;">
  <text class="loading-text">加载中...</text>
</view>

<view wx:elif="{{loadError}}" class="empty-state" style="padding-top: 200rpx;">
  <text class="empty-icon">⚠️</text>
  <text class="empty-title">加载失败</text>
  <text class="empty-desc">无法获取统计数据，请检查网络后重试</text>
  <view class="retry-btn" bindtap="onRetry">
    <text>🔄 重新加载</text>
  </view>
</view>

<view wx:elif="{{stats}}" class="page-stats">
  <!-- Summary Cards -->
  <view class="summary-row">
    <view class="summary-card">
      <text class="summary-value">{{stats.totalBrews}}</text>
      <text class="summary-label">总冲煮</text>
    </view>
    <view class="summary-card">
      <text class="summary-value">{{stats.goodRate || '0%'}}</text>
      <text class="summary-label">好喝率</text>
    </view>
  </view>

  <!-- Good / Bad counts -->
  <view class="card" wx:if="{{stats.totalBrews > 0}}">
    <view class="section-title"><text class="icon">☕</text><text>味道统计</text></view>
    <view class="taste-stats-row">
      <view class="taste-stat-item">
        <text class="taste-stat-emoji">👍</text>
        <text class="taste-stat-count">{{stats.goodCount || 0}}</text>
        <text class="taste-stat-label">好喝</text>
      </view>
      <view class="taste-stat-item">
        <text class="taste-stat-emoji">👎</text>
        <text class="taste-stat-count">{{stats.badCount || 0}}</text>
        <text class="taste-stat-label">难喝</text>
      </view>
    </view>

    <!-- Top bad reasons -->
    <view wx:if="{{stats.topBadReasons && stats.topBadReasons.length > 0}}" class="top-bad-reasons">
      <text class="top-bad-title">常见问题</text>
      <view class="top-bad-tags">
        <text class="tag tag-reason" wx:for="{{stats.topBadReasons}}" wx:key="*this">{{f.getBadReason(item)}}</text>
      </view>
    </view>
  </view>

  <!-- Method Stats -->
  <view class="card" wx:if="{{methodStatsList.length > 0}}">
    <view class="section-title"><text class="icon">⚙️</text><text>冲煮方式</text></view>
    <view class="method-stat-row" wx:for="{{methodStatsList}}" wx:key="method">
      <text class="method-stat-label">{{item.label}}</text>
      <view class="method-stat-bar-wrap">
        <view class="method-stat-bar" style="width: {{stats.totalBrews > 0 ? (item.count / stats.totalBrews * 100) : 0}}%"></view>
      </view>
      <text class="method-stat-count">{{item.count}}次</text>
    </view>
  </view>

  <!-- Empty -->
  <view wx:if="{{stats.totalBrews === 0}}" class="empty-state">
    <text class="empty-icon">📊</text>
    <text class="empty-title">暂无统计数据</text>
    <text class="empty-desc">开始记录你的咖啡，数据会在这里汇总</text>
  </view>
  <view class="safe-bottom"></view>
</view>
