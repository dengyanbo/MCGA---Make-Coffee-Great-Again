<wxs src="../../utils/filters.wxs" module="f" />

<view wx:if="{{loading}}" class="loading-wrap" style="padding-top: 200rpx;">
  <text class="loading-text">加载中...</text>
</view>

<!-- Error State -->
<view wx:elif="{{loadError}}" class="empty-state" style="padding-top: 200rpx;">
  <text class="empty-icon">⚠️</text>
  <text class="empty-title">加载失败</text>
  <text class="empty-desc">无法获取统计数据，请检查网络后重试</text>
  <view class="retry-btn" bindtap="onRetry">
    <text>🔄 重新加载</text>
  </view>
</view>

<scroll-view wx:elif="{{stats}}" scroll-y class="page-stats">
  <!-- Summary Cards -->
  <view class="summary-row">
    <view class="summary-card">
      <text class="summary-value">{{stats.totalBrews}}</text>
      <text class="summary-label">总冲煮次数</text>
    </view>
    <view class="summary-card">
      <text class="summary-value">{{stats.avgOverall}}</text>
      <text class="summary-label">平均评分</text>
    </view>
  </view>

  <!-- Per-method collapsible sections -->
  <view wx:if="{{methodStatsList.length > 0}}">
    <view class="card method-group" wx:for="{{methodStatsList}}" wx:key="method">
      <!-- Method header (always visible, tap to toggle) -->
      <view class="method-header" bindtap="onToggleMethod" data-method="{{item.method}}">
        <view class="method-header-left">
          <text class="method-name">{{item.label}}</text>
          <text class="method-summary">{{item.count}}次 · 均分 {{item.avgOverall}}</text>
        </view>
        <text class="method-arrow {{item.expanded ? 'expanded' : ''}}">▶</text>
      </view>

      <!-- Expanded content -->
      <view wx:if="{{item.expanded}}" class="method-detail">
        <!-- Per-method average scores -->
        <view class="method-scores">
          <view class="score-stat-row" wx:for="{{item.scoreDims}}" wx:for-item="score" wx:key="dim">
            <text class="score-stat-label">{{score.label}}</text>
            <view class="score-stat-bar-wrap">
              <view class="score-stat-bar" style="width: {{score.percent}}%;"></view>
            </view>
            <text class="score-stat-value">{{score.score}}</text>
          </view>
        </view>

        <!-- Per-method log entries -->
        <view class="method-logs">
          <view class="method-log-item" wx:for="{{item.logs}}" wx:for-item="log" wx:key="_id">
            <view class="method-log-top">
              <text class="method-log-bean">{{log.beanName}}</text>
              <text class="method-log-score">{{log.overall || '-'}}</text>
            </view>
            <view class="method-log-bottom">
              <text class="method-log-params">{{log.coffeeDose}}g · {{log.waterAmount}}ml · {{f.formatTime(log.brewTime)}}</text>
              <text class="method-log-date">{{f.formatDate(log.createdAt)}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- Empty Stats -->
  <view wx:if="{{stats.totalBrews === 0}}" class="empty-state">
    <text class="empty-icon">📊</text>
    <text class="empty-title">暂无统计数据</text>
    <text class="empty-desc">开始记录你的咖啡，数据会在这里汇总</text>
  </view>
  <view class="safe-bottom"></view>
</scroll-view>
