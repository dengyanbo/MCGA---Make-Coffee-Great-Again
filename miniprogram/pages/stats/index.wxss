.page-stats {
  height: 100vh;
}

/* Summary Row */
.summary-row {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
}

.summary-card {
  flex: 1;
  background: linear-gradient(135deg, #4A2C2A, #6F4E37);
  border-radius: 20rpx;
  padding: 36rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
}

.summary-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 12rpx;
}

/* Method Stats */
.method-stats {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.method-stat-row {
  display: flex;
  align-items: center;
}

.method-stat-label {
  font-size: 26rpx;
  color: #6F4E37;
  min-width: 100rpx;
}

.method-stat-bar-wrap {
  flex: 1;
  height: 20rpx;
  background: #F0EBE3;
  border-radius: 10rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.method-stat-bar {
  height: 100%;
  background: linear-gradient(90deg, #C4A882, #6F4E37);
  border-radius: 10rpx;
  min-width: 8rpx;
}

.method-stat-count {
  font-size: 24rpx;
  color: #8B7355;
  min-width: 60rpx;
  text-align: right;
}

/* Collapsible Method Groups */
.method-group {
  padding: 0 !important;
  overflow: hidden;
}

.method-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}

.method-header:active {
  background: #FAF5EF;
}

.method-header-left {
  flex: 1;
}

.method-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #4A2C2A;
  display: block;
}

.method-summary {
  font-size: 24rpx;
  color: #8B7355;
  margin-top: 4rpx;
  display: block;
}

.method-arrow {
  font-size: 24rpx;
  color: #C4A882;
  transition: transform 0.3s ease;
}

.method-arrow.expanded {
  transform: rotate(90deg);
}

.method-detail {
  border-top: 1rpx solid #F0EBE3;
  padding: 24rpx 32rpx;
}

.method-scores {
  margin-bottom: 24rpx;
}

.method-logs {
  border-top: 1rpx solid #F0EBE3;
  padding-top: 20rpx;
}

.method-log-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F8F4EE;
}

.method-log-item:last-child {
  border-bottom: none;
}

.method-log-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.method-log-bean {
  font-size: 28rpx;
  font-weight: 500;
  color: #2D1810;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.method-log-score {
  font-size: 36rpx;
  font-weight: 700;
  color: #4A2C2A;
  margin-left: 16rpx;
}

.method-log-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}

.method-log-params {
  font-size: 22rpx;
  color: #8B7355;
}

.method-log-date {
  font-size: 22rpx;
  color: #C4A882;
}

/* Score Stats */
.score-stats {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.score-stat-row {
  display: flex;
  align-items: center;
}

.score-stat-label {
  font-size: 26rpx;
  color: #6F4E37;
  min-width: 100rpx;
}

.score-stat-bar-wrap {
  flex: 1;
  height: 16rpx;
  background: #F0EBE3;
  border-radius: 8rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.score-stat-bar {
  height: 100%;
  background: linear-gradient(90deg, #D4AF37, #C4A882);
  border-radius: 8rpx;
  min-width: 4rpx;
}

.score-stat-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A2C2A;
  min-width: 60rpx;
  text-align: right;
}

.safe-bottom {
  height: 60rpx;
}
