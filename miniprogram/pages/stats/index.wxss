.page-stats {
  min-height: 100vh;
}

.summary-row {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
}

.summary-card {
  flex: 1;
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(20px);
  border-radius: 20rpx;
  padding: 36rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 0.5rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.summary-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #1C1C1E;
  line-height: 1;
}

.summary-label {
  font-size: 24rpx;
  color: #8E8E93;
  margin-top: 12rpx;
}

/* Taste Stats */
.taste-stats-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.taste-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.taste-stat-emoji {
  font-size: 48rpx;
}

.taste-stat-count {
  font-size: 40rpx;
  font-weight: 700;
  color: #1C1C1E;
}

.taste-stat-label {
  font-size: 22rpx;
  color: #8E8E93;
}

.top-bad-reasons {
  padding-top: 24rpx;
  border-top: 0.5rpx solid #F2F2F7;
}

.top-bad-title {
  font-size: 24rpx;
  color: #8E8E93;
  display: block;
  margin-bottom: 12rpx;
}

.top-bad-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

/* Method Stats */
.method-stat-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.method-stat-row:last-child {
  margin-bottom: 0;
}

.method-stat-label {
  font-size: 26rpx;
  color: #3A3A3C;
  min-width: 80rpx;
  font-weight: 500;
}

.method-stat-bar-wrap {
  flex: 1;
  height: 20rpx;
  background: #E5E5EA;
  border-radius: 10rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.method-stat-bar {
  height: 100%;
  background: #1C1C1E;
  border-radius: 10rpx;
  min-width: 8rpx;
  transition: width 0.5s;
}

.method-stat-count {
  font-size: 24rpx;
  color: #8E8E93;
  min-width: 60rpx;
  text-align: right;
}

.safe-bottom {
  height: 60rpx;
}
