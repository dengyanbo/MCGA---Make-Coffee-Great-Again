.page-stats {
  min-height: 100vh;
}

/* Summary Row */
.summary-row {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
}

.summary-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 36rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #1C1C1E;
  line-height: 1;
}

.summary-label {
  font-size: 24rpx;
  color: #8E8E93;
  margin-top: 12rpx;
}

/* Method Stats */
.method-stats {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.method-stat-row {
  display: flex;
  align-items: center;
}

.method-stat-label {
  font-size: 26rpx;
  color: #3A3A3C;
  min-width: 100rpx;
}

.method-stat-bar-wrap {
  flex: 1;
  height: 20rpx;
  background: #E5E5EA;
  border-radius: 10rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.method-stat-bar {
  height: 100%;
  background: linear-gradient(90deg, #AEAEB2, #C7C7CC);
  border-radius: 10rpx;
  min-width: 8rpx;
}

.method-stat-count {
  font-size: 24rpx;
  color: #8E8E93;
  min-width: 60rpx;
  text-align: right;
}

/* Method Overall Score */
.method-overall-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.method-overall-label {
  font-size: 28rpx;
  color: #3A3A3C;
  margin-right: auto;
}

.method-overall-score {
  font-size: 44rpx;
  font-weight: 700;
  color: #1C1C1E;
  line-height: 1;
}

.method-overall-max {
  font-size: 22rpx;
  color: #AEAEB2;
  margin-left: 4rpx;
}

.method-radar-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 8rpx;
}

/* Collapsible Method Groups */
.method-group {
  padding: 0 !important;
  overflow: hidden;
}

.method-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}

.method-header:active {
  background: #F2F2F7;
}

.method-header-left {
  flex: 1;
}

.method-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1C1E;
  display: block;
}

.method-summary {
  font-size: 24rpx;
  color: #8E8E93;
  margin-top: 4rpx;
  display: block;
}

.method-arrow {
  font-size: 24rpx;
  color: #C7C7CC;
  transition: transform 0.3s ease;
}

.method-arrow.expanded {
  transform: rotate(90deg);
}

.method-detail {
  border-top: 1rpx solid #F2F2F7;
  padding: 24rpx 32rpx;
}

.method-scores {
  margin-bottom: 24rpx;
}

.method-logs {
  border-top: 1rpx solid #F2F2F7;
  padding-top: 20rpx;
}

.method-log-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F2F2F7;
}

.method-log-item:last-child {
  border-bottom: none;
}

.method-log-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.method-log-bean {
  font-size: 28rpx;
  font-weight: 500;
  color: #1C1C1E;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.method-log-score {
  font-size: 36rpx;
  font-weight: 700;
  color: #1C1C1E;
  margin-left: 16rpx;
}

.method-log-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}

.method-log-params {
  font-size: 22rpx;
  color: #8E8E93;
}

.method-log-date {
  font-size: 22rpx;
  color: #AEAEB2;
}

.safe-bottom {
  height: 60rpx;
}
