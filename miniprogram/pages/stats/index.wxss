.page-stats {
  height: 100vh;
}

/* Summary Row */
.summary-row {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
}

.summary-card {
  flex: 1;
  background: linear-gradient(135deg, #4A2C2A, #6F4E37);
  border-radius: 20rpx;
  padding: 36rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
}

.summary-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 12rpx;
}

/* Method Stats */
.method-stats {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.method-stat-row {
  display: flex;
  align-items: center;
}

.method-stat-label {
  font-size: 26rpx;
  color: #6F4E37;
  min-width: 100rpx;
}

.method-stat-bar-wrap {
  flex: 1;
  height: 20rpx;
  background: #F0EBE3;
  border-radius: 10rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.method-stat-bar {
  height: 100%;
  background: linear-gradient(90deg, #C4A882, #6F4E37);
  border-radius: 10rpx;
  min-width: 8rpx;
}

.method-stat-count {
  font-size: 24rpx;
  color: #8B7355;
  min-width: 60rpx;
  text-align: right;
}

/* Score Stats */
.score-stats {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.score-stat-row {
  display: flex;
  align-items: center;
}

.score-stat-label {
  font-size: 26rpx;
  color: #6F4E37;
  min-width: 100rpx;
}

.score-stat-bar-wrap {
  flex: 1;
  height: 16rpx;
  background: #F0EBE3;
  border-radius: 8rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.score-stat-bar {
  height: 100%;
  background: linear-gradient(90deg, #D4AF37, #C4A882);
  border-radius: 8rpx;
  min-width: 4rpx;
}

.score-stat-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A2C2A;
  min-width: 60rpx;
  text-align: right;
}

.safe-bottom {
  height: 60rpx;
}
