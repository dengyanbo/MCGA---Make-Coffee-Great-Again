var methods = {
  pourover: '手冲',
  coldbrew: '冷萃'
}

var roasts = {
  light: '浅烘',
  medium_light: '中浅',
  medium: '中度',
  medium_dark: '中深',
  dark: '深烘'
}

var tastes = {
  good: '好喝',
  bad: '难喝'
}

var badReasons = {
  too_bitter: '太苦',
  too_sour: '太酸'
}

var techniques = {
  yidaoliu: '一刀流',
  sanduanshi: '三段式'
}

function getBrewMethod(method) {
  return methods[method] || method || '--'
}

function getRoast(level) {
  return roasts[level] || level || '--'
}

function getTaste(taste) {
  return tastes[taste] || taste || '--'
}

function getBadReason(reason) {
  if (!reason) return '--'
  if (reason.indexOf('other:') === 0) {
    return reason.substring(6) || '其他'
  }
  return badReasons[reason] || reason
}

function getBrewTechnique(technique) {
  return techniques[technique] || technique || '--'
}

function formatDate(dateStr) {
  if (!dateStr) return ''
  var d = getDate(dateStr)
  var month = d.getMonth() + 1
  var day = d.getDate()
  return month + '月' + day + '日'
}

function formatFullDate(dateStr) {
  if (!dateStr) return ''
  var d = getDate(dateStr)
  var y = d.getFullYear()
  var month = d.getMonth() + 1
  var day = d.getDate()
  var h = d.getHours()
  var m = d.getMinutes()
  return y + '/' + month + '/' + day + ' ' + (h < 10 ? '0' + h : h) + ':' + (m < 10 ? '0' + m : m)
}

function formatTime(seconds) {
  if (!seconds && seconds !== 0) return '--'
  var m = Math.floor(seconds / 60)
  var s = seconds % 60
  if (m > 0) return m + "'" + (s < 10 ? '0' + s : s) + '"'
  return s + '"'
}

function formatRatio(dose, water) {
  if (!dose || !water) return '--'
  var r = water / dose
  return '1:' + r.toFixed(1)
}

function getBrewTitle(item) {
  if (!item) return '冲煮记录'
  var parts = []
  if (item.brewMethod) parts.push(methods[item.brewMethod] || item.brewMethod)
  if (item.brewTechnique) parts.push(techniques[item.brewTechnique] || item.brewTechnique)
  if (item.filterCup) parts.push(item.filterCup)
  return parts.length > 0 ? parts.join(' ') : '冲煮记录'
}

module.exports = {
  getBrewMethod: getBrewMethod,
  getRoast: getRoast,
  getTaste: getTaste,
  getBadReason: getBadReason,
  getBrewTechnique: getBrewTechnique,
  getBrewTitle: getBrewTitle,
  formatDate: formatDate,
  formatFullDate: formatFullDate,
  formatTime: formatTime,
  formatRatio: formatRatio
}
